// Blueprint for the database. Two tables: Company (potential clients) and AIOpportunity (product features to build).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// Company = a property management company found during market research
model Company {
  id            String   @id @default(uuid())
  name          String
  website       String?
  country       String?
  city          String?          // City where the company operates
  address       String?          // Full street address
  phone         String?
  services      String?
  employeeCount String?
  companyType   String?          // "property_manager" | "real_estate" | "admin_agency"
  rating        Float?           // Average star rating (e.g. 4.2)
  reviewCount   Int?             // Total number of reviews
  reviews       String?          // JSON array of review texts — where pain points live
  notes         String?
  addedAt       DateTime @default(now())
}

// AIOpportunity = a specific AI feature idea for our future product
model AIOpportunity {
  id          String   @id @default(uuid())
  title       String                   // e.g. "Chatbot for resident queries"
  description String?                  // what it does and how
  targetArea  String?                  // e.g. "communication", "billing", "maintenance"
  viability   Int?                     // 1 (speculative) to 5 (proven market demand)
  notes       String?                  // which companies need it, competitors, risks
  addedAt     DateTime @default(now())
}
